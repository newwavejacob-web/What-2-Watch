# Copy to .env and fill in. Never commit the real .env.

# OpenAI: required for real vibe search + embedding generation (imports).
# Without it the app runs with placeholder (non-semantic) embeddings.
OPENAI_API_KEY=sk-...

# TMDB: required only for the movie import tool (cmd/tmdb-import).
# Get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Signs the httpOnly session cookie. Generate with: openssl rand -hex 32
# Keep it stable in production so sessions survive restarts.
SESSION_SECRET=

# Gates /stats and /admin/scrape. Sent via the X-Admin-Secret header.
# Generate with: openssl rand -hex 24. If unset, admin endpoints are disabled.
ADMIN_SECRET=

# Max OpenAI-billed requests per minute, per session (falls back to client IP).
RATE_LIMIT_PER_MINUTE=20

# Only needed if the SPA is served from a different origin than the API.
# Comma-separated, e.g. https://chidaucf.win
CORS_ALLOWED_ORIGINS=
